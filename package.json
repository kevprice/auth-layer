{
  "name": "auth-layer",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:migrate": "tsx packages/core/scripts/migrate.ts",
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev -w @auth-layer/api",
    "dev:web": "npm run dev -w @auth-layer/web",
    "dev:worker": "npm run dev -w @auth-layer/worker",
    "build": "npm run build -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "test": "vitest run",
    "proof:export": "tsx packages/core/scripts/export-proof-package.ts",
    "proof:verify": "tsx packages/core/scripts/verify-proof-package.ts",
    "transparency:checkpoint": "tsx packages/core/scripts/export-transparency-checkpoint.ts",
    "transparency:operator-key": "tsx packages/core/scripts/export-operator-public-key.ts",
    "examples:generate": "tsx packages/core/scripts/generate-example-packages.ts"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.17.30",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "jsdom": "^26.0.0",
    "pg-mem": "^3.0.5",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9"
  }
}
